# Supabase
# Local: http://localhost:54321 | Cloud: https://<project>.supabase.co
SUPABASE_URL=http://localhost:54321

# Supabase anon (public) key — safe to expose in browser
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — NEVER expose publicly; bypasses RLS
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT secret used by Supabase to sign auth tokens (from Supabase dashboard → Settings → API)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ES256 public key — required for the API to verify JWTs issued by newer Supabase instances.
# Local: run `supabase status` and copy the "JWT S256 Public Key" value (include BEGIN/END lines).
# Cloud: Settings → API → JWT Settings → JWT public key.
# Omit or leave blank to fall back to HS256 verification via SUPABASE_JWT_SECRET.
SUPABASE_JWT_PUBLIC_KEY=""

# AI Provider (OpenAI-compatible)
# OpenAI:   AI_BASE_URL=https://api.openai.com/v1
# Groq:     AI_BASE_URL=https://api.groq.com/openai/v1, AI_MODEL=llama3-70b-8192
# Together: AI_BASE_URL=https://api.together.xyz/v1
# Ollama:   AI_BASE_URL=http://localhost:11434/v1, AI_API_KEY=ollama, EMBEDDING_MODEL=nomic-embed-text
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o-mini

# Embedding model — any dimension works (the DB uses a dimensionless vector column).
# Switch freely between providers without a schema migration.
# Use 'make use-ollama' or 'make use-openai' to swap all AI vars at once.
EMBEDDING_MODEL=text-embedding-ada-002

# Backend
API_PORT=3001

# Frontend (public — safe to expose)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
